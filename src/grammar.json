{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "a2ml",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_toplevel"
      }
    },
    "_toplevel": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "section_delimiter"
        },
        {
          "type": "SYMBOL",
          "name": "section_heading"
        },
        {
          "type": "SYMBOL",
          "name": "subsection_heading"
        },
        {
          "type": "SYMBOL",
          "name": "key_value_pair"
        },
        {
          "type": "SYMBOL",
          "name": "attestation_block"
        },
        {
          "type": "SYMBOL",
          "name": "list_item"
        },
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "blank_line"
        }
      ]
    },
    "blank_line": {
      "type": "PATTERN",
      "value": "\\n"
    },
    "section_delimiter": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 10,
        "content": {
          "type": "PATTERN",
          "value": "---\\n"
        }
      }
    },
    "section_heading": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 5,
        "content": {
          "type": "PATTERN",
          "value": "#{2,6} *\\[[A-Z_][A-Z0-9_\\/]*\\]\\n"
        }
      }
    },
    "subsection_heading": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 3,
        "content": {
          "type": "PATTERN",
          "value": "#{2,6} +[^\\[\\n][^\\n]*\\n"
        }
      }
    },
    "key_value_pair": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "key"
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "PATTERN",
                  "value": " +"
                },
                {
                  "type": "SYMBOL",
                  "name": "value"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "key": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "hash_key"
        },
        {
          "type": "SYMBOL",
          "name": "plain_key"
        }
      ]
    },
    "plain_key": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_.\\/\\-]*"
    },
    "hash_key": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "PATTERN",
          "value": "#[a-zA-Z_][a-zA-Z0-9_\\-]*"
        }
      }
    },
    "value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "quoted_string"
        },
        {
          "type": "SYMBOL",
          "name": "array"
        },
        {
          "type": "SYMBOL",
          "name": "block_scalar_indicator"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "boolean"
        },
        {
          "type": "SYMBOL",
          "name": "null_value"
        },
        {
          "type": "SYMBOL",
          "name": "unquoted_string"
        }
      ]
    },
    "quoted_string": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "\""
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "double_string_content"
                },
                {
                  "type": "BLANK"
                }
              ]
            },
            {
              "type": "STRING",
              "value": "\""
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "'"
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "single_string_content"
                },
                {
                  "type": "BLANK"
                }
              ]
            },
            {
              "type": "STRING",
              "value": "'"
            }
          ]
        }
      ]
    },
    "double_string_content": {
      "type": "PATTERN",
      "value": "[^\"\\\\]*(?:\\\\.[^\"\\\\]*)*"
    },
    "single_string_content": {
      "type": "PATTERN",
      "value": "[^'\\\\]*(?:\\\\.[^'\\\\]*)*"
    },
    "array": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "value"
                },
                {
                  "type": "REPEAT",
                  "content": {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "STRING",
                        "value": ","
                      },
                      {
                        "type": "SYMBOL",
                        "name": "value"
                      }
                    ]
                  }
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "STRING",
                      "value": ","
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "number": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "\\-?[0-9]+(\\.[0-9]+)?"
        }
      }
    },
    "boolean": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "true"
            },
            {
              "type": "STRING",
              "value": "false"
            }
          ]
        }
      }
    },
    "null_value": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "STRING",
          "value": "null"
        }
      }
    },
    "unquoted_string": {
      "type": "PATTERN",
      "value": "[^\\n\\[\\]\"',:# ][^\\n]*"
    },
    "block_scalar_indicator": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "|"
            },
            {
              "type": "STRING",
              "value": ">"
            }
          ]
        }
      }
    },
    "attestation_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "attestation_start"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "attestation_content"
          }
        },
        {
          "type": "SYMBOL",
          "name": "attestation_end"
        }
      ]
    },
    "attestation_start": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 5,
        "content": {
          "type": "PATTERN",
          "value": "@[a-zA-Z_][a-zA-Z0-9_]*:\\n"
        }
      }
    },
    "attestation_content": {
      "type": "PATTERN",
      "value": "[^@\\n][^\\n]*\\n"
    },
    "attestation_end": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 5,
        "content": {
          "type": "PATTERN",
          "value": "@end\\n?"
        }
      }
    },
    "list_item": {
      "type": "SEQ",
      "members": [
        {
          "type": "TOKEN",
          "content": {
            "type": "PREC",
            "value": 3,
            "content": {
              "type": "STRING",
              "value": "- "
            }
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "key"
                },
                {
                  "type": "STRING",
                  "value": ":"
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "SEQ",
                      "members": [
                        {
                          "type": "PATTERN",
                          "value": " +"
                        },
                        {
                          "type": "SYMBOL",
                          "name": "value"
                        }
                      ]
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                }
              ]
            },
            {
              "type": "SYMBOL",
              "name": "value"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "# [^\\n]*\\n?"
        }
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": " "
    },
    {
      "type": "PATTERN",
      "value": "\\t"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}